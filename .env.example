# Database (Supabase PostgreSQL)
# Pooled connection (for runtime queries via Prisma)
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@aws-1-us-east-1.pooler.supabase.com:6543/postgres"
# Direct connection (for migrations/schema push — bypasses connection pooler)
DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres"

# AI
ANTHROPIC_API_KEY=

# Data APIs
CONGRESS_GOV_API_KEY=
GOOGLE_CIVIC_API_KEY=
LEGISCAN_API_KEY=
FEC_API_KEY=

# Caching
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# CourtListener (Free Law Project) — free token from courtlistener.com/sign-in/
# Optional: works without auth but has lower rate limits
COURTLISTENER_API_TOKEN=

# Cron job auth — generate with: openssl rand -base64 32
CRON_SECRET=

# Email (Resend — free tier: 3,000 emails/month)
RESEND_API_KEY=
EMAIL_FROM="InformedVoter <notifications@knowyourgov.us>"

# Base URL for email links (verification, unsubscribe)
NEXT_PUBLIC_BASE_URL=https://knowyourgov.us

# ⚠️  NEVER SET THIS IN PRODUCTION — bypasses auth on all /api/cron/* routes.
# Only for local dev: allows ?manual=true to trigger cron routes without a Bearer token.
# ALLOW_MANUAL_CRON=true
