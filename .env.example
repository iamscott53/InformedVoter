# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres"

# AI
ANTHROPIC_API_KEY=

# Data APIs
CONGRESS_GOV_API_KEY=
GOOGLE_CIVIC_API_KEY=
LEGISCAN_API_KEY=
FEC_API_KEY=

# Caching
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# CourtListener (Free Law Project) — free token from courtlistener.com/sign-in/
# Optional: works without auth but has lower rate limits
COURTLISTENER_API_TOKEN=

# Cron job auth — generate with: openssl rand -base64 32
CRON_SECRET=

# Set to "true" to allow ?manual=true bypass on /api/cron/* routes (dev only)
# ALLOW_MANUAL_CRON=true
